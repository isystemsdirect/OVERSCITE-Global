rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }
    
    function isInspector() {
      return hasRole('inspector') || isAdmin();
    }

    // =========================
    // BANE Org/Entitlements layer (LFCB-02)
    // =========================
    function orgMemberPath(orgId) {
      return /databases/$(database)/documents/orgs/$(orgId)/members/$(uid());
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && exists(orgMemberPath(orgId));
    }

    function orgMemberRole(orgId) {
      return get(orgMemberPath(orgId)).data.role;
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && (orgMemberRole(orgId) in ['owner', 'admin']);
    }

    // =========================
    // Evidence / Chain-of-Custody (LFCB-03)
    // =========================
    function isOrgMemberByInspection(inspectionId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/inspections/$(inspectionId)) &&
        exists(
          /databases/$(database)/documents/orgs/$(get(/databases/$(database)/documents/inspections/$(inspectionId)).data.orgId)/members/$(uid())
        );
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own document
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can update their own document (limited fields)
      allow update: if isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'createdAt']));
      
      // Only admins can create or delete users
      allow create, delete: if isAdmin();
    }
    
    // Sessions collection
    match /sessions/{sessionId} {
      allow read, write: if isOwner(resource.data.user_id);
    }
    
    // Inspections collection
    match /inspections/{inspectionId} {
      // Read: Owner, team members, or admins
      allow read: if isAuthenticated() && (
        resource.data.created_by == request.auth.uid ||
        request.auth.uid in resource.data.get('team', []) ||
        isAdmin()
      );
      
      // Create: Any authenticated inspector
      allow create: if isInspector() && 
        request.resource.data.created_by == request.auth.uid;
      
      // Update: Owner or admin
      allow update: if isAuthenticated() && (
        resource.data.created_by == request.auth.uid ||
        isAdmin()
      );
      
      // Delete: Only admin
      allow delete: if isAdmin();

      // Evidence canonical stores
      match /artifacts/{artifactId} {
        allow read: if isOrgMemberByInspection(inspectionId);
        allow create: if isOrgMemberByInspection(inspectionId);
        allow update: if isOrgMemberByInspection(inspectionId) && resource.data.finalized == false;
        allow delete: if false;
      }

      match /artifactEvents/{eventId} {
        allow read: if isOrgMemberByInspection(inspectionId);
        allow write: if false;
      }

      match /classifications/{classificationId} {
        allow read: if isOrgMemberByInspection(inspectionId);
        allow write: if false;
      }

      match /mapLayers/{layerId} {
        allow read: if isOrgMemberByInspection(inspectionId);
        allow write: if false;
      }

      match /telemetry/{telemetryId} {
        allow read: if isOrgMemberByInspection(inspectionId);
        allow write: if false;
      }

      // SCING-only report blocks (Admin SDK bypasses rules)
      match /reportBlocks/{blockId} {
        allow read: if isOrgMemberByInspection(inspectionId);
        allow write: if false;
      }
      
      // Findings subcollection
      match /findings/{findingId} {
        allow read: if isOrgMemberByInspection(inspectionId);
        allow write: if false;
      }
    }

    // Evidence audit sinks (server only)
    match /audit/evidenceEvents/events/{eventId} {
      allow read: if false;
      allow write: if false;
    }

    match /audit/wormHeads/{scopeId} {
      allow read: if false;
      allow write: if false;
    }

    // =========================
    // Observability events (LFCB-10)
    // =========================
    match /obs/events/{eventId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    
    // Tasks collection
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (
        resource.data.assigned_to == request.auth.uid ||
        resource.data.created_by == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isInspector();
      
      allow update: if isAuthenticated() && (
        resource.data.assigned_to == request.auth.uid ||
        resource.data.created_by == request.auth.uid ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    
    // Security Decision Records (SDRs)
    match /sdrs/{sdrId} {
      // Only admins can read SDRs
      allow read: if isAdmin();
      
      // Only Cloud Functions can write SDRs
      allow write: if false;
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.created_by == request.auth.uid ||
        request.auth.uid in resource.data.get('shared_with', []) ||
        isAdmin()
      );
      
      // Only Cloud Functions can create reports
      allow create: if false;
      
      allow delete: if isAdmin();
    }

    // Orgs / members / devices / entitlements / policy snapshots
    match /orgs/{orgId} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgAdmin(orgId);

      match /members/{memberUid} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId);
      }

      match /devices/{deviceId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId) || (isAuthenticated() && request.resource.data.boundToUid == uid());
      }

      match /entitlements/{entId} {
        allow read: if isOrgMember(orgId);
        allow write: if false; // BANE-only via Admin SDK
      }

      match /policySnapshots/{snapUid} {
        allow read: if isAuthenticated() && snapUid == uid() && isOrgMember(orgId);
        allow write: if false; // BANE-only via Admin SDK
      }
    }

    // BANE audit (WORM-like append-only; Admin SDK only)
    match /audit/baneEvents/events/{eventId} {
      allow read: if false;
      allow write: if false;
    }
    
    // =========================
    // Scing Cloud Core (UTCB-G: Scing Bring-Up)
    // =========================

    // Scing session documents — owner can read, server writes via Admin SDK
    match /scingSessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == uid();
      allow write: if false; // Admin SDK only (server-side session management)

      // Session messages subcollection — owner can read, server writes
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          get(/databases/$(database)/documents/scingSessions/$(sessionId)).data.userId == uid();
        allow write: if false; // Admin SDK only
      }
    }

    // Scing audit events (append-only; Admin SDK only)
    match /audit/scingEvents/events/{eventId} {
      allow read: if false;
      allow write: if false;
    }

    // Scing governance receipts (append-only; Admin SDK only)
    match /audit/scingGovernance/receipts/{receiptId} {
      allow read: if false;
      allow write: if false;
    }

    // =========================
    // OVERSCITE Global Marketplace — UTCB-S V1.0
    // All 16 market_ collections — Admin SDK only for writes
    // Reads scoped to authenticated org members or authorized roles
    // =========================

    // --- Field Market Plane (Plane 1) ---

    // market_jobs — org-scoped read; Admin SDK only write (mutations via Cloud Functions)
    match /market_jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only (publishJob, closeJobAndPreparePayout)
    }

    // market_job_offers — restrict to offer parties; Admin SDK only write
    match /market_job_offers/{offerId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only (issueDispatchOffer, acceptJobOffer)
    }

    // market_agent_profiles — authenticated read; Admin SDK only write
    match /market_agent_profiles/{agentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // market_availability — authenticated read; Admin SDK only write
    match /market_availability/{availId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // market_payouts — financial data; auth and org-scoped read; Admin SDK only write
    match /market_payouts/{payoutId} {
      // Read restricted to authenticated users — Firestore rules cannot inspect org roles
      // without a read; final role enforcement is handled by Cloud Function and App layer.
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only (closeJobAndPreparePayout)
    }

    // --- Marketplace Plane (Plane 2) ---

    // market_products — public read for live/beta products; Admin SDK only write
    match /market_products/{productId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only (publishMarketProduct)
    }

    // market_product_versions — authenticated read; Admin SDK only write
    match /market_product_versions/{versionId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // market_lari_keys — org/user-scoped sensitive read; Admin SDK only write
    match /market_lari_keys/{keyId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only (activateEntitlement, revokeEntitlement)
    }

    // market_entitlements — org/user-scoped read; Admin SDK only write
    // CRITICAL: pending ≠ active — status must be server-authoritative at all times
    match /market_entitlements/{entitlementId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only (activateEntitlement, revokeEntitlement)
    }

    // --- Shared Collections ---

    // market_reputation_packets — authenticated read; Admin SDK only write
    match /market_reputation_packets/{repId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // market_orders — org/user-scoped read; Admin SDK only write
    // Both planes — order_plane field distinguishes origin
    match /market_orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only (createMarketOrder)
    }

    // market_transactions — Admin SDK only (financial records)
    match /market_transactions/{transId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // market_disputes — dispute access restricted; Admin SDK only write
    match /market_disputes/{disputeId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // market_billing_events — WORM-like append-only; Admin SDK only
    match /market_billing_events/{eventId} {
      allow read: if false; // Finance admin access via Admin SDK / Cloud Function only
      allow write: if false; // Admin SDK only (append-only billing ledger)
    }

    // market_moderation_records — Admin SDK only; reviewer access via Admin SDK
    match /market_moderation_records/{recordId} {
      allow read: if false; // Reviewer access via Admin SDK / Cloud Function only
      allow write: if false; // Cloud Functions only (requestStandaloneAuthorization)
    }

    // market_audit_events — WORM-like append-only; Admin SDK only; BANE-governed
    match /market_audit_events/{eventId} {
      allow read: if false; // Compliance access via Admin SDK / Cloud Function only
      allow write: if false; // Admin SDK only — immutable audit chain (recordMarketAuditEvent)
    }

    // =========================
    // UTCB-S (STRICT) Enforcement Rule Set
    // No direct client writes allowed to core systems
    // =========================
    
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if false; // scing.recordAsset gateway only
    }

    match /conversations/{msgId} {
      allow read: if isAuthenticated();
      allow write: if false; // scing.recordConversationMessage gateway only
    }

    match /conversationSessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == uid();
      allow write: if false; // scing.createConversationSession gateway only
    }

    match /security_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // scing.logSecurityEvent gateway only
    }

    // BANE Protocol Internals (Immutable Audit Chain)
    match /bane_audits/{auditId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /bane_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /bane_incidents/{incidentId} {
      allow read: if isInspector();
      allow write: if false;
    }
    match /bane_governance/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default: deny all access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}